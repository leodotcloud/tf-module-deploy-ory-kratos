# providers.tf.example — Copy to providers.tf and configure for your environment.
# This file is gitignored because provider config is environment-specific.

provider "helm" {
  kubernetes = {
    config_path    = "~/.kube/config"
    config_context = "your-cluster-context"  # e.g., "k3d-dev", "k3s-preprod"
  }
}

provider "kubernetes" {
  config_path    = "~/.kube/config"
  config_context = "your-cluster-context"
}
